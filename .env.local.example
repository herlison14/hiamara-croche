# =================== Mercado Pago ===================
# Access Token: dashboard.mercadopago.com.br > Suas integrações > Credenciais
MERCADOPAGO_ACCESS_TOKEN=your-mp-access-token
MERCADOPAGO_PUBLIC_KEY=your-mp-public-key

# Segredo para validar a assinatura do webhook (header x-signature).
# Configure em: dashboard.mercadopago.com.br > Webhooks > "Sua chave secreta"
# OBRIGATÓRIA em produção. Em dev local (SITE_URL contém "localhost"), pode ficar vazia.
MERCADOPAGO_WEBHOOK_SECRET=

# =================== Site ===================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

